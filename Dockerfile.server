# =============================================================================
# WudiBuddy Agents Server — multi-platform Docker image
#
# Build:
#   docker buildx build -f Dockerfile.server -t craft-agent-server .
#
# Run (use --user to match host UID/GID for volume permissions):
#   docker run --rm -p 9100:9100 \
#     --user $(id -u):$(id -g) \
#     -e HOME=/home/craftagents \
#     -e CRAFT_SERVER_TOKEN=<secret> \
#     craft-agent-server
#
# Run with TLS + mounted config:
#   docker run --rm -p 9100:9100 \
#     --user $(id -u):$(id -g) \
#     -e HOME=/home/craftagents \
#     -e CRAFT_SERVER_TOKEN=<secret> \
#     -e CRAFT_RPC_TLS_CERT=/certs/cert.pem \
#     -e CRAFT_RPC_TLS_KEY=/certs/key.pem \
#     -v /path/to/certs:/certs:ro \
#     -v ~/.craft-agent:/home/craftagents/.craft-agent \
#     craft-agent-server
# =============================================================================

FROM oven/bun:1.3.10-slim

LABEL org.opencontainers.image.source="https://github.com/lukilabs/craft-agents-oss"
LABEL org.opencontainers.image.description="WudiBuddy Agents Server — headless AI workflow server"
LABEL org.opencontainers.image.licenses="Apache-2.0"

# Install system deps + Node.js (required by the WhatsApp worker subprocess;
# Bun cannot run Baileys' crypto deps). Pin Node to a major via NodeSource so
# upgrades are explicit — must match the --target in scripts/build-wa-worker.ts.
ARG NODE_MAJOR=22
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates git ripgrep curl gnupg && \
    curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user (Claude Code SDK refuses to run as root).
# At runtime, override with --user $(id -u):$(id -g) to match host permissions.
RUN groupadd -r craftagents && \
    useradd -r -g craftagents -m -d /home/craftagents -s /bin/bash craftagents

WORKDIR /app

# Copy dependency manifests first for layer caching.
# `bunfig.toml` MUST be in the WORKDIR before `bun install` runs — it sets
# `linker = "hoisted"`, which is required for the WebUI / renderer build
# (transitive deps like i18next, @tiptap/*, pdfjs-dist resolve at top-level
# node_modules). Without it Bun defaults to isolated installs and the Vite
# build fails on the first transitive bare-package import.
COPY package.json bun.lock bunfig.toml ./
COPY packages/server/package.json packages/server/
COPY packages/server-core/package.json packages/server-core/
COPY packages/shared/package.json packages/shared/
COPY packages/core/package.json packages/core/
COPY packages/session-tools-core/package.json packages/session-tools-core/
COPY packages/session-mcp-server/package.json packages/session-mcp-server/
COPY packages/pi-agent-server/package.json packages/pi-agent-server/
COPY packages/ui/package.json packages/ui/
COPY packages/messaging-gateway/package.json packages/messaging-gateway/
COPY packages/messaging-whatsapp-worker/package.json packages/messaging-whatsapp-worker/
COPY apps/electron/package.json apps/electron/
COPY apps/cli/package.json apps/cli/
COPY apps/viewer/package.json apps/viewer/
COPY apps/webui/package.json apps/webui/

# The server image builds required artifacts explicitly below. Skip workspace
# lifecycle scripts during dependency install so desktop-only hooks/downloads
# cannot stall the headless image build.
RUN HUSKY=0 \
    ELECTRON_SKIP_BINARY_DOWNLOAD=1 \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    PUPPETEER_SKIP_DOWNLOAD=1 \
    bun install --frozen-lockfile --ignore-scripts --backend=copyfile --linker=isolated \
      --filter @craft-agent/server \
      --filter @craft-agent/server-core \
      --filter @craft-agent/shared \
      --filter @craft-agent/core \
      --filter @craft-agent/session-tools-core \
      --filter @craft-agent/session-mcp-server \
      --filter @craft-agent/pi-agent-server \
      --filter @craft-agent/messaging-gateway \
      --filter @craft-agent/messaging-whatsapp-worker \
      --filter @craft-agent/webui \
      --filter @craft-agent/ui

# Copy source
COPY . .

# Build helper servers as ESM bundles for Node. Some dependencies use
# import.meta, so CJS bundles fail once executed by node.
RUN bun build packages/session-mcp-server/src/index.ts \
      --outfile packages/session-mcp-server/dist/index.mjs --target node --format esm && \
    bun build packages/pi-agent-server/src/index.ts \
      --outfile packages/pi-agent-server/dist/index.mjs --target node --format esm

# Build the WhatsApp worker bundle (CJS, Node target — Bun cannot run it).
RUN bun run scripts/build-wa-worker.ts

# Build web UI assets (served by the server on the RPC port).
# vite's bundler runs under Node (via shebang in vite's bin) and hits V8's
# default ~2GB heap cap on the rendering phase (>5k modules). Raise to 4GB
# so low-RAM build hosts (e.g. 4GB VPS) can complete the build.
RUN NODE_OPTIONS="--max-old-space-size=4096" bunx vite build --config apps/webui/vite.config.ts

# Pre-create .craft-agent so Docker named volumes inherit the correct permissions.
RUN mkdir -p /home/craftagents/.craft-agent

# Make app world-readable so any --user can run it. Home dir is writable for .craft-agent.
# Use find to only touch files/dirs missing the read bit — much faster than chmod -R on the
# entire tree (node_modules alone has hundreds of thousands of entries).
RUN find /app -not -perm -o=r -exec chmod o+r {} + && \
    find /app -type d -not -perm -o=x -exec chmod o+x {} + && \
    chmod -R 777 /home/craftagents

USER craftagents

ENV CRAFT_RPC_HOST=0.0.0.0
ENV CRAFT_RPC_PORT=9100
ENV CRAFT_WEBUI_DIR=/app/apps/webui/dist
ENV CRAFT_BUNDLED_ASSETS_ROOT=/app/apps/electron
# WhatsApp worker — Bun cannot run the CJS worker, so we point the adapter at
# system `node` (installed above). If CRAFT_BUNDLED_ASSETS_ROOT changes, update
# CRAFT_MESSAGING_WA_WORKER to match; the default in packages/server resolves
# against CRAFT_BUNDLED_ASSETS_ROOT, but the layout above flattens to /app.
ENV CRAFT_MESSAGING_WA_WORKER=/app/packages/messaging-whatsapp-worker/dist/worker.cjs
ENV CRAFT_MESSAGING_NODE_BIN=node
ENV CRAFT_BACKEND_NODE_BIN=node

EXPOSE 9100

ENTRYPOINT ["bun", "run", "packages/server/src/index.ts"]
